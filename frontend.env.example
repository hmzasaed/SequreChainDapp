# ============================================
# SeQureChain — Frontend Environment Variables
# ============================================
# Copy this file to ".env" in the same folder and fill in real values.
# NEVER commit the real ".env" file — it is already in .gitignore.
#
# Note: Expo requires the EXPO_PUBLIC_ prefix for any variable that
# needs to be accessible in client-side code. These values end up
# bundled into the app, so do NOT put private keys or secret keys here
# — only public-safe config (API URLs, Firebase client config, etc.)

# Backend API URL
EXPO_PUBLIC_API_URL=http://localhost:5000

# Smart Contract
EXPO_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedEvidenceManagerAddress
EXPO_PUBLIC_CHAIN_ID=11155111

# Firebase Client SDK (safe to expose — from Firebase Console > Project Settings > General)
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# Pinata Gateway (for retrieving/displaying IPFS files)
EXPO_PUBLIC_PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
